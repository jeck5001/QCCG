# Required: your Qoder PAT token
QODER_PAT=your-pat-token-here

# Region: "global" or "cn" (default: global)
QCCG_REGION=global

# Auth token for bridge access (default: "qccg")
# Set a custom token to restrict access to the bridge
QCCG_BRIDGE_TOKEN=qccg

# Log level: "info", "debug", or "error" (default: info)
QCCG_LOG_LEVEL=info
